# .env files are local-only fallback; Doppler is source of truth in prod
# See README.md for Doppler setup instructions

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://www.cosmocrat.ai
SITE_ENV=development
# Optional legacy stage flag; SEO/indexing logic uses SITE_ENV only.
SITE_STAGE=dev
DOCS_URL=
CONTACT_EMAIL=contact@cosmocrat.ai

# --- Supabase (server only) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (server only) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=contact@cosmocrat.ai
RESEND_REPLY_TO=contact@cosmocrat.ai
WAITLIST_NOTIFY_EMAIL=

# --- Security ---
IP_HASH_SALT=change-me
